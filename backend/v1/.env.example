# =============================================================================
# Bot Builder Backend - Environment Variables Example
# =============================================================================
# Copy this file to .env and update with your actual values
#
# IMPORTANT: This configuration uses NESTED structure with double underscores
# Example: DATABASE__URL, SECURITY__SECRET_KEY, REDIS__URL
#
# The nested structure maps to Pydantic settings in config.py:
#   DATABASE__URL        → settings.database.url
#   SECURITY__SECRET_KEY → settings.security.secret_key
#   REDIS__URL           → settings.redis.url
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection URL (nested with DATABASE__)
DATABASE__URL=postgresql+asyncpg://botbuilder:password@localhost:5432/botbuilder

# Connection pool settings (nested with DATABASE__)
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20
DATABASE__ECHO=false

# =============================================================================
# REDIS CONFIGURATION (MANDATORY - required for rate limiting and token blacklisting)
# =============================================================================
# Redis connection URL (nested with REDIS__)
REDIS__URL=redis://localhost:6379/0

# Redis connection settings (nested with REDIS__)
REDIS__SOCKET_TIMEOUT=5
REDIS__SOCKET_CONNECT_TIMEOUT=2
REDIS__MAX_RECONNECT_ATTEMPTS=3
REDIS__RECONNECT_BACKOFF_CAP=30

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Cache TTLs in seconds (nested with CACHE__)
CACHE__FLOW_TTL=3600
CACHE__SESSION_TTL=1800

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT settings (nested with SECURITY__)
SECURITY__SECRET_KEY=CHANGEME_generate_secure_random_key_at_least_32_chars
SECURITY__ENCRYPTION_KEY=CHANGEME_generate_fernet_encryption_key_44_chars
SECURITY__ALGORITHM=HS256
SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=4320
SECURITY__BCRYPT_ROUNDS=12

# IMPORTANT: Generate secure keys with:
#   SECRET_KEY:     python -c 'import secrets; print(secrets.token_urlsafe(32))'
#   ENCRYPTION_KEY: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
#
# The ENCRYPTION_KEY is used for PII encryption (channel_user_id, session context, flow snapshots)
# It must be exactly 44 characters (base64-encoded 32 bytes) for Fernet encryption

# =============================================================================
# GOOGLE OAUTH CONFIGURATION
# =============================================================================
# Google OAuth2 credentials (nested with GOOGLE__)
# Obtain these from Google Cloud Console (https://console.cloud.google.com/)
GOOGLE__CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE__CLIENT_SECRET=your-client-secret
GOOGLE__REDIRECT_URI=http://localhost:8000/auth/google/callback

# For production, update GOOGLE__REDIRECT_URI to your production URL:
# GOOGLE__REDIRECT_URI=https://yourdomain.com/auth/google/callback

# =============================================================================
# RATE LIMITING CONFIGURATION
# =============================================================================
# Rate limits for webhooks (nested with RATE_LIMIT__)
RATE_LIMIT__WEBHOOK_MAX=10
RATE_LIMIT__WEBHOOK_WINDOW=60

# Rate limits for authenticated users (nested with RATE_LIMIT__)
RATE_LIMIT__USER_MAX=100
RATE_LIMIT__USER_WINDOW=60

# Rate limits for registration (nested with RATE_LIMIT__)
RATE_LIMIT__REGISTER_MAX=5
RATE_LIMIT__REGISTER_WINDOW=3600

# Rate limits for login (nested with RATE_LIMIT__)
RATE_LIMIT__LOGIN_MAX=10
RATE_LIMIT__LOGIN_WINDOW=3600

# =============================================================================
# HTTP CLIENT CONFIGURATION
# =============================================================================
# HTTP client settings for API calls (nested with HTTP_CLIENT__)
HTTP_CLIENT__TIMEOUT=30.0
HTTP_CLIENT__MAX_CONNECTIONS=100
HTTP_CLIENT__MAX_KEEPALIVE=20

# =============================================================================
# FLOW CONSTRAINTS CONFIGURATION
# =============================================================================
# Flow execution limits (nested with FLOW_CONSTRAINTS__)
FLOW_CONSTRAINTS__MAX_FLOW_SIZE=1048576
FLOW_CONSTRAINTS__MAX_AUTO_PROGRESSION=10
FLOW_CONSTRAINTS__SESSION_TIMEOUT_MINUTES=30

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Application metadata (lowercase, not nested)
app_name=Bot Builder
app_version=1.0.0
environment=development
debug=true
base_url=http://localhost:8000
frontend_url=http://localhost:5173

# CORS origins (comma-separated, lowercase, not nested)
allowed_origins=http://localhost:3000,http://localhost:5173,http://localhost:8000

# =============================================================================
# EVOLUTION API CONFIGURATION (WhatsApp Integration)
# =============================================================================
# Evolution API integration for WhatsApp (nested with EVOLUTION_API__)
EVOLUTION_API__ENABLED=true
EVOLUTION_API__URL=http://evolution-api:8080
EVOLUTION_API__API_KEY=CHANGEME_generate_32_char_key_for_evolution_api
EVOLUTION_API__WEBHOOK_BASE_URL=http://api:8000

# For HTTPS access to Evolution API (via Caddy proxy):
# When using API_ACTION nodes to call Evolution API, use the HTTPS endpoint:
#   Production:  https://your-domain.com/evolution/...
#   Development: https://localhost:8443/...
#
# This allows API_ACTION nodes to securely call Evolution API while maintaining
# the HTTPS-only requirement for external API calls.
#
# Generate secure Evolution API key with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'

# =============================================================================
# OBSERVABILITY CONFIGURATION
# =============================================================================
# Sentry error tracking (nested with OBSERVABILITY__)
# Get DSN from: https://sentry.io/ (free tier available)
OBSERVABILITY__SENTRY_DSN=
OBSERVABILITY__SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics (nested with OBSERVABILITY__)
# Exposes /metrics endpoint for scraping
OBSERVABILITY__PROMETHEUS_ENABLED=true

# =============================================================================
# MONITORING CONFIGURATION (Optional - for WhatsApp)
# =============================================================================
# Grafana admin password (for WhatsApp monitoring)
GRAFANA_PASSWORD=admin

# =============================================================================
# DOCKER COMPOSE CONFIGURATION
# =============================================================================
# These are used by docker-compose.yml
DB_PASSWORD=password
REDIS_PASSWORD=CHANGEME_generate_redis_password
SECRET_KEY=CHANGEME_generate_secure_random_key_at_least_32_chars
ENCRYPTION_KEY=CHANGEME_generate_fernet_encryption_key_44_chars
EVOLUTION_API_KEY=CHANGEME_generate_32_char_key_for_evolution_api
VITE_API_URL=http://localhost:8000
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# PRODUCTION NOTES
# =============================================================================
# In production, make sure to:
# 1. Set environment=production
# 2. Set debug=false
# 3. Update base_url to your actual domain (e.g., https://api.yourdomain.com)
# 4. Update frontend_url to your actual frontend domain (e.g., https://yourdomain.com)
# 5. Update GOOGLE__REDIRECT_URI to match your production domain
# 6. Generate a strong SECURITY__SECRET_KEY (python -c 'import secrets; print(secrets.token_urlsafe(32))')
# 7. Generate a secure SECURITY__ENCRYPTION_KEY (python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')
# 8. Use strong database password (DB_PASSWORD) and Redis password (REDIS_PASSWORD)
# 9. Configure proper CORS origins
# 10. Set VITE_API_URL to your production API domain (baked into frontend at build time)
# 11. Consider disabling DATABASE__ECHO for performance
# 12. Generate secure EVOLUTION_API_KEY (python -c 'import secrets; print(secrets.token_urlsafe(32))')
# 13. Update Caddyfile with your production domain for Evolution API HTTPS access
# 14. Change GRAFANA_PASSWORD from default if using monitoring
# 15. Configure OBSERVABILITY__SENTRY_DSN for error tracking (get DSN from sentry.io)
# 16. Adjust OBSERVABILITY__SENTRY_TRACES_SAMPLE_RATE for production (0.1 = 10% of requests)
#
# CRITICAL: Never lose your ENCRYPTION_KEY! If lost, all encrypted session data becomes unrecoverable.
# Backup this key securely in a password manager or key management service (AWS KMS, HashiCorp Vault, etc.)
# =============================================================================

# =============================================================================
# EXTERNAL API CREDENTIALS (Optional)
# =============================================================================
# Add your external API keys here if needed for API_ACTION nodes
# These should be injected server-side, NOT stored in flow definitions
# Example:
# EXTERNAL_PAYMENT_API_KEY=your-payment-api-key-here
# EXTERNAL_SMS_API_KEY=your-sms-api-key-here
# =============================================================================
